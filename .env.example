# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# ===== Database: Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ===== Payments: Stripe =====
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Analytics =====
NEXT_PUBLIC_ANALYTICS_ID=

# ===== Optional MCPs (only if you enable them in .mcp.json) =====
SENTRY_AUTH_TOKEN=
GITHUB_PAT=

# ===== arc-council cross-model juror (v3) =====
# Any OpenAI-compatible provider works — set base URL + model + key (free tiers fine).
# Examples: Groq  https://api.groq.com/openai/v1            (model: llama-3.3-70b-versatile)
#           Gemini https://generativelanguage.googleapis.com/v1beta/openai  (model: gemini-2.0-flash)
#           OpenRouter https://openrouter.ai/api/v1          (model: deepseek/deepseek-chat-v3-0324:free)
#           DeepSeek https://api.deepseek.com                (model: deepseek-chat)
# Unset = deep runs proceed with "Juror: unavailable (not configured)" (offline-first, ADR-0016).
JUROR_BASE_URL=
JUROR_MODEL=
JUROR_API_KEY=
# Optional: per-attempt timeout in ms (default 60000)
JUROR_TIMEOUT_MS=

# Second provider — used to prove the env-only provider switch (REQ-03); the runner maps JUROR2_* → JUROR_*
JUROR2_BASE_URL=
JUROR2_MODEL=
JUROR2_API_KEY=

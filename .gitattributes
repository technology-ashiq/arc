# Cross-platform line-ending policy (PLAN pre-mortem #6: Windows breakage).
# Shell scripts, bats tests, and YAML MUST be LF on checkout everywhere, or
# bash on Linux CI chokes on carriage returns. Authored on Windows Git Bash,
# executed on ubuntu CI -- LF is non-negotiable for anything a shell runs.
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf
*.bats  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Evidence bundles are sha256-hash-pinned (ADR-0002): git must NOT rewrite their
# bytes (line endings included) or tamper-verification breaks on checkout across
# platforms. Freeze them exactly as hashed -- this OVERRIDES `* text=auto eol=lf`.
docs/evidence/** -text

# Binary assets: never touch.
*.png binary
*.jpg binary
*.gif binary
*.ico binary

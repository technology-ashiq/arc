# === Secrets & environment ===
.env
.env.*
!.env.example

# === Claude private / machine-local (NEVER pushed) ===
CLAUDE.local.md
.claude/settings.local.json

# === Dependencies ===
node_modules/
.pnp.*

# === Build output ===
.next/
out/
dist/
build/

# === Logs ===
*.log
npm-debug.log*
yarn-error.log*
# ...but evidence bundles ARE committed proof (test-output.log included) — never ignore them.
!docs/evidence/**

# === OS / editor junk ===
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# === Test / coverage ===
coverage/
playwright-report/
test-results/

# Hook scratch state (PreCompact snapshots, graphify lock/log)
.claude/state/

# arc-registry.json is a per-INSTALL artifact written into consumer targets, never the mold
# itself (Phase 02, REQ-08). It's excluded from the golden + tree-diff gates by design, so
# ignore it here too — a stray one can never be silently committed into the mold's .claude/.
.claude/arc-registry.json

# Hook write-probes (freeze-check / edit-guard test their write access) — never commit
.writetest*
**/.writetest
*.wt
**/.wt

# Graphify: fully local + regenerable (rebuilds each session via the SessionStart hook)
# and holds machine-specific paths (.graphify_root, .graphify_python) — never commit any of it.
graphify-out/

# Codex
.codex
.agents
AGENTS.md

# Planner-bench output (large, regenerable — not committed despite the evidence rule above)
docs/evidence/planner-bench/

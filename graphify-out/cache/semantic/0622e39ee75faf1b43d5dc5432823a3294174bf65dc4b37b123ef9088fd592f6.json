{"nodes": [{"id": "docs_usermanual", "label": "User Manual \u2014 Sample Structure (arc- system)", "file_type": "document", "source_file": "docs/usermanual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_usermanual_arc_twist", "label": "The Arc Twist", "file_type": "rationale", "source_file": "docs/usermanual.md", "source_location": "\u00a70", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Whatever gets done must produce a committed artifact + a gate + resumable state \u2014 not just a report. Enforcement, not assertion, is presented as the source of the whole system's power."}, {"id": "docs_usermanual_review_ledger_gates", "label": "Review Ledger + Gates", "file_type": "rationale", "source_file": "docs/usermanual.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A per-commit-SHA ledger records which reviews (qa/security/design/docs) have passed; any new commit resets the ledger so code is always re-reviewed honestly, and ship is blocked until the required reviews are stamped."}, {"id": "docs_usermanual_arc_vs_gstack", "label": "arc vs gstack Division of Labor", "file_type": "rationale", "source_file": "docs/usermanual.md", "source_location": "\u00a712", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One-owner-per-job: throwaway/preview work (design exploration, general browsing, ad-hoc knowledge bases) is delegated to gstack tooling, while anything that must end in a decision, a gate, or a tracked deliverable stays inside arc, avoiding duplicated workflow ownership."}], "edges": [{"source": "docs_usermanual", "target": "docs_usermanual_arc_twist", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/usermanual.md", "source_location": "\u00a70", "weight": 1.0}, {"source": "docs_userma
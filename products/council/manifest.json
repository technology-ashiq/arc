    ".claude/agents/council-verifier.md",
    ".claude/agents/council-researcher.md",
    ".claude/agents/council-strategist.md",
    ".claude/agents/council-risk-analyst.md",
    ".claude/agents/council-marketer.md",
    ".claude/agents/council-designer.md",
    ".claude/agents/council-engineer.md",
    ".claude/agents/council-policy-analyst.md",
    ".claude/agents/council-life-counselor.md"
  ],
  "scripts": [
